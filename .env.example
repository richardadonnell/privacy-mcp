# Privacy.com MCP Server — environment variables
# Copy this file to .env and fill in values for local development.
# In Coolify (production), set these via the Coolify secrets UI — do NOT commit a filled .env file.

# Privacy.com API key — get from https://privacy.com/account/developer
# This key is also used as the HMAC secret to verify incoming webhook signatures.
PRIVACY_API_KEY=

# Set to "true" to hit sandbox.privacy.com instead of api.privacy.com.
# Sandbox lets you test card creation, transactions, and webhooks without real charges.
# Pan/CVV are not restricted in sandbox (Enterprise-only in production).
PRIVACY_SANDBOX=false

# API key that protects all /mcp and /api/* endpoints on this server.
# Used in Authorization: Bearer <MCP_API_KEY> by Claude Desktop (via uvx mcp-proxy) and n8n.
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=

# Port to use for both host mapping and container listener.
# Defaults to 8001 to avoid colliding with monarch-mcp on 8000.
PORT=8001
